{
  "name": "aionboarding-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 0.0.0.0 --port 5173",
    "typecheck": "tsc --noEmit",
    "generate:api": "openapi-typescript ../backend/application/src/main/resources/api/v1/specs/openapi.yaml -o src/shared/api/generated/schema.d.ts",
    "check:api": "npm run generate:api && tsc --noEmit",
    "test": "vitest run --environment jsdom",
    "bundle:report": "bash ../scripts/report-bundle-size.sh"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.0",
    "@clerk/clerk-react": "^5.20.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@floating-ui/react": "^0.27.19",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource/barlow-semi-condensed": "^5.2.7",
    "@mui/icons-material": "^9.1.1",
    "@mui/material": "^9.1.1",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@tanstack/react-query": "^5.62.0",
    "@tiptap/core": "^3.22.4",
    "@tiptap/extension-highlight": "^3.22.4",
    "@tiptap/extension-horizontal-rule": "^3.22.4",
    "@tiptap/extension-image": "^3.22.4",
    "@tiptap/extension-list": "^3.22.4",
    "@tiptap/extension-subscript": "^3.22.4",
    "@tiptap/extension-superscript": "^3.22.4",
    "@tiptap/extension-text-align": "^3.22.4",
    "@tiptap/extension-typography": "^3.22.4",
    "@tiptap/extensions": "^3.22.4",
    "@tiptap/pm": "^3.22.4",
    "@tiptap/react": "^3.22.4",
    "@tiptap/starter-kit": "^3.22.4",
    "@tsparticles/confetti": "^4.1.1",
    "class-variance-authority": "^0.7.1",
    "dompurify": "^3.4.12",
    "lodash.throttle": "^4.1.1",
    "openapi-fetch": "^0.13.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hotkeys-hook": "^5.2.4",
    "react-router-dom": "^7.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/lodash.throttle": "^4.1.9",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^5.2.0",
    "jsdom": "^25.0.1",
    "openapi-typescript": "^7.4.0",
    "sass": "^1.100.0",
    "typescript": "^5.7.0",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  }
}

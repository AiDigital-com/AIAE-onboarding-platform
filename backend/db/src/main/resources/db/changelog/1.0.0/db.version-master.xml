    <changeSet id="1.0.0-jsonb-array-contains-ci-function" author="aionboarding">
        <preConditions onFail="MARK_RAN">
            <dbms type="postgresql"/>
            <sqlCheck expectedResult="0">
                SELECT COUNT(*) FROM information_schema.routines
                WHERE routine_schema = 'public' AND routine_name = 'jsonb_array_contains_ci'
            </sqlCheck>
        </preConditions>
        <sqlFile path="sql/jsonb_array_contains_ci_function.sql" relativeToChangelogFile="true" splitStatements="false"/>
        <rollback>
            <sql dbms="postgresql">DROP FUNCTION IF EXISTS jsonb_array_contains_ci(jsonb, text);</sql>
        </rollback>
    </changeSet>


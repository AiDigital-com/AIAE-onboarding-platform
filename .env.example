# =============================================================================
# .env.example — production/Replit-first defaults.
# Copy only the needed keys into Replit Secrets. Keep secret values out of git.
#
# Anything prefixed with VITE_ is exposed to the browser by Vite. NEVER put
# secrets there.
# =============================================================================

# -- Spring profile -----------------------------------------------------------
SPRING_PROFILES_ACTIVE=replit

# -- Server -------------------------------------------------------------------
PORT=5000
APP_CONTEXT_PATH=
APP_SERVICE_NAME=aionboarding
BACKEND_DEV_PORT=5000
VITE_API_BASE_URL=
VITE_API_CONTEXT_PATH=

# -- PostgreSQL ---------------------------------------------------------------
# Replit PostgreSQL injects PGHOST, PGPORT, PGDATABASE, PGUSER, and PGPASSWORD.
# These POSTGRES_* values are only local fallbacks.
POSTGRES_DB=app
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# -- Auth (Clerk SSO — the ONLY auth mode) -----------------------------------
# Replit-managed Clerk Auth injects CLERK_PUBLISHABLE_KEY + CLERK_SECRET_KEY.
# Issuer/JWKS derive from the publishable key — do not paste AUTH_ISSUER_URI
# unless you intentionally override the Replit-managed tenant.
AUTH_ALLOWED_EMAIL_DOMAIN=aidigital.com
# Comma-separated EXACT trusted browser origins for the JWT azp claim.
# Required in Replit Secrets. Example:
# AUTH_AUTHORIZED_PARTIES=https://your-app.your-user.replit.app
AUTH_AUTHORIZED_PARTIES=
AUTH_ISSUER_URI=
AUTH_JWKS_URI=
AUTH_AUDIENCE=
CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_SIGN_IN_FORCE_REDIRECT_URL=/
CLERK_SIGN_UP_FORCE_REDIRECT_URL=/

# -- Auth (frontend, Vite-exposed) -------------------------------------------
VITE_CLERK_PUBLISHABLE_KEY=
VITE_CLERK_JWT_TEMPLATE=aidigital-api
VITE_CLERK_SIGN_IN_FORCE_REDIRECT_URL=/
VITE_CLERK_SIGN_UP_FORCE_REDIRECT_URL=/

# -- Usage logging (PostgresUsageLogger → usage_events table) ----------------
USAGE_LOGGING_ENABLED=true
USAGE_LOG_SERVICE_NAME=aionboarding
USAGE_LOG_ENVIRONMENT=prod

# -- JVM (Docker backend only) -----------------------------------------------
JAVA_OPTS=

# -- External setup (informational; configured in Clerk Dashboard) -----------
# GOOGLE_CLIENT_ID and GOOGLE_CLIENT_SECRET live inside Clerk in the preferred
# flow. Do NOT inject these into the application runtime.

APP_EXTERNAL_HTTP_MAX_TOTAL_CONNECTIONS=50

APP_EXTERNAL_HTTP_MAX_CONNECTIONS_PER_ROUTE=10

APP_EXTERNAL_HTTP_CONNECT_TIMEOUT=5s

APP_EXTERNAL_HTTP_RESPONSE_TIMEOUT=30s

APP_EXTERNAL_HTTP_CONNECTION_REQUEST_TIMEOUT=5s

OPENAI_ENABLED=true

OPENAI_BASE_URL=https://api.openai.com

OPENAI_API_KEY=

OPENAI_MODEL=gpt-4o

OPENAI_MAX_TOKENS=1024

OPENAI_API_MODE=responses

# -- Object storage (S3-compatible; mirrors storage.js fallback chains) -------
STORAGE_ENABLED=true
REGION=
AWS_REGION=
S3_REGION=
RAILWAY_BUCKET_REGION=
ENDPOINT=
AWS_ENDPOINT=
S3_ENDPOINT=
RAILWAY_BUCKET_ENDPOINT=
ACCESS_KEY_ID=
AWS_ACCESS_KEY_ID=
S3_ACCESS_KEY_ID=
RAILWAY_BUCKET_ACCESS_KEY_ID=
SECRET_ACCESS_KEY=
AWS_SECRET_ACCESS_KEY=
S3_SECRET_ACCESS_KEY=
RAILWAY_BUCKET_SECRET_ACCESS_KEY=
BUCKET=
AWS_BUCKET=
S3_BUCKET=
RAILWAY_BUCKET_BUCKET=
STORAGE_FORCE_PATH_STYLE=true

# -- HeyGen (teacher video renders) ------------------------------------------
HEYGEN_ENABLED=true
HEYGEN_BASE_URL=https://api.heygen.com
HEYGEN_API_KEY=
HEYGEN_TEACHER_AVATAR_ID=
HEYGEN_AVATAR_ID=
HEYGEN_AVATAR_LOOK_ID=
HEYGEN_TEACHER_VOICE_ID=
HEYGEN_VOICE_ID=

# -- YouTube (oEmbed + transcript scraping) ----------------------------------
YOUTUBE_ENABLED=true
YOUTUBE_TRANSCRIPT_LANG=
YOUTUBE_TRANSCRIPT_DEBUG=false
